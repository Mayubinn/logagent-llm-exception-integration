exception:
  llm:
    # 总开关。true 开启异常分析，false 关闭。
    enabled: false

    # OpenAI Chat Completions 接口地址；如果你们有兼容网关，也可以替换成自己的地址。
    llm-api-url: https://api.openai.com/v1/chat/completions
    # 默认模型。普通通用场景可以直接用 gpt-4o-mini。
    llm-model: gpt-4o-mini
    # OpenAI 使用 Authorization 头，值通常是 Bearer + API Key。
    auth-header-name: Authorization
    auth-token: "Bearer your-openai-api-key"

    # 是否把调用方传入的请求上下文一起发给模型。
    include-request-context: true
    # 是否附带 queryString。
    include-query-string: false
    # 是否附带客户端 IP。
    include-client-ip: false
    # 是否附带 traceId。
    include-trace-id: true
    # 是否附带处理器签名，例如 Controller#method。
    include-handler-signature: true
    # 从 MDC 里读取 traceId 时使用的 key。
    trace-id-mdc-key: traceId
    # 请求上下文最大长度，避免上下文过长。
    max-context-length: 1024

    # 是否提取异常发生点附近的源码/反编译代码。
    code-context-enabled: true
    # 代码窗口：异常行前取多少行。
    code-context-lines-before: 20
    # 代码窗口：异常行后取多少行。
    code-context-lines-after: 20
    # 整体代码上下文最大长度，避免 prompt 过长。
    code-context-max-chars: 12000
    # 本地源码缺失时，是否继续从 sources.jar 中找源码。
    search-sources-jar: true
    # sources.jar 也没有时，是否反编译 class。
    decompile-when-source-missing: true
    # 最多附带几个关键堆栈帧的代码片段。
    max-code-frames: 2
    # 业务包前缀。建议配置，不然只能靠排除框架包来识别业务代码。
    application-packages:
      - com.example.demo
    # 本地源码根目录，用于从工作区读取 .java 文件。
    source-roots:
      - src/main/java
      - src/test/java

    # 分析结果输出方式：LOG / STDOUT / CALLBACK。
    output-mode: LOG
    # 模型最大输出 token 数。
    max-tokens: 1500
    # 采样温度，越低越稳定。
    temperature: 0.2
    # 异常/函数栈最大长度；超出后会按字符截断，避免发送给模型的 prompt 过大。
    max-exception-chars: 16000

    # 线程池核心线程数。
    core-pool-size: 1
    # 线程池最大线程数。
    max-pool-size: 2
    # 异步任务队列大小。
    queue-capacity: 64
    # 空闲线程存活时间（秒）。
    keep-alive-sec: 60

    # HTTP 连接超时（秒）。
    connect-timeout-sec: 10
    # HTTP 读取超时（秒）。
    read-timeout-sec: 60
    # HTTP 写入超时（秒）。
    write-timeout-sec: 10

    # 透传给下游的遥测字段，可按需自定义。
    telemetry-name: logagent
    telemetry-client-name: logagent-exception-analyzer-sdk
    telemetry-client-version: 1.0.1
